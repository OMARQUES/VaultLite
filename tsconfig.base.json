{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@vaultlite/domain": ["packages/domain/src/index.ts"],
      "@vaultlite/crypto": ["packages/crypto/src/index.ts"],
      "@vaultlite/contracts": ["packages/contracts/src/index.ts"],
      "@vaultlite/storage-abstractions": ["packages/storage-abstractions/src/index.ts"],
      "@vaultlite/runtime-abstractions": ["packages/runtime-abstractions/src/index.ts"],
      "@vaultlite/test-utils": ["packages/test-utils/src/index.ts"],
      "@vaultlite/cloudflare-storage": ["adapters/cloudflare-storage/src/index.ts"],
      "@vaultlite/cloudflare-runtime": ["adapters/cloudflare-runtime/src/index.ts"]
    }
  }
}
